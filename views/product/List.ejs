<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<title>Products</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<nav class="navbar navbar-dark bg-dark mb-4">
<div class="container">
<span class="navbar-brand">Product Management</span>
</div>
</nav>

<div class="container">

<div class="d-flex justify-content-between mb-4">
<h3>Products</h3>
<a href="/api/home" class="btn btn-primary">Add Product</a>
</div>

<form method="GET" action="/api/all" class="row g-3 mb-4">

<div class="col-md-3">
<select name="category" class="form-select">
<option value="">All Category</option>
<% categories.forEach(cat => { %>
<option value="<%= cat %>"><%= cat %></option>
<% }) %>
</select>
</div>

<div class="col-md-3">
<select name="size" class="form-select">
<option value="">All Size</option>
<% sizes.forEach(size => { %>
<option value="<%= size %>"><%= size %></option>
<% }) %>
</select>
</div>

<div class="col-md-3">
<select name="color" class="form-select">
<option value="">All Color</option>
<% colors.forEach(color => { %>
<option value="<%= color %>"><%= color %></option>
<% }) %>
</select>
</div>

<div class="col-md-3">
<button class="btn btn-success w-100">Filter</button>
</div>

</form>

<table class="table table-bordered table-striped">

<thead class="table-dark">
<tr>
<th>Name</th>
<th>Description</th>
<th>Price</th>
<th>Category</th>
<th>Size</th>
<th>Color</th>
<th>Stock</th>
<th>Actions</th>
</tr>
</thead>

<tbody>

<% products.forEach(product => { %>

<tr>
<td><%= product.name %></td>
<td><%= product.description %></td>
<td>RS. <%= product.price %></td>
<td><%= product.category %></td>
<td><%= product.size %></td>
<td><%= product.color %></td>
<td><%= product.stock %></td>

<td>

<a href="/api/edit/<%= product._id %>" class="btn btn-warning btn-sm">
Edit
</a>

<form action="/api/delete/<%= product._id %>" method="POST" style="display:inline;">
<button class="btn btn-danger btn-sm">Delete</button>
</form>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>