<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<title>Products</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<style>

/* BODY */
body {
  background: #f5f6fa;
}

/* CARD */
.product-card {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  transition: 0.3s;
}

.product-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.08);
}

/* IMAGE */
.img-box {
  position: relative;
  overflow: hidden;
}

.img-box img {
  width: 100%;
  height: 260px;
  object-fit: cover;
  transition: 0.4s;
}

.product-card:hover img {
  transform: scale(1.08);
}

/* ICONS */
.action-icons {
  position: absolute;
  top: 10px;
  right: 10px;
  display: flex;
  gap: 8px;
  opacity: 0;
  transition: 0.3s;
}

.product-card:hover .action-icons {
  opacity: 1;
}

.icon {
  background: #fff;
  border: none;
  padding: 6px 8px;
  border-radius: 50%;
  font-size: 14px;
  cursor: pointer;
  box-shadow: 0 2px 6px rgba(0,0,0,0.15);
}

.icon.edit {
  color: #ffc107;
}

.icon.delete {
  color: #dc3545;
}

/* SALE TAG */
.badge-sale {
  position: absolute;
  top: 10px;
  left: 10px;
  background: red;
  color: #fff;
  font-size: 12px;
  padding: 4px 8px;
  border-radius: 4px;
}

/* FILTER */
.filter-box {
  position: sticky;
  top: 20px;
  border-radius: 12px;
}

/* RADIO */
.form-check-input:checked {
  background-color: #198754;
  border-color: #198754;
}

/* PRICE */
.price {
  color: #198754;
  font-weight: 600;
}

</style>

</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-dark bg-dark mb-4">
  <div class="container">
    <span class="navbar-brand fw-semibold">Product Management</span>
  </div>
</nav>

<div class="container">

  <!-- HEADER -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-semibold">Products</h3>
    <a href="/home" class="btn btn-primary px-4">+ Add Product</a>
  </div>

  <div class="row">

    <!-- 🔵 FILTER -->
    <div class="col-lg-3">

      <form method="GET" action="/" class="bg-white p-4 shadow-sm filter-box">

        <h5 class="mb-4 fw-semibold">Filters</h5>

        <!-- CATEGORY -->
        <div class="mb-4">
          <p class="fw-semibold mb-2">Category</p>
          <hr>

          <div class="form-check">
            <input class="form-check-input" type="radio" name="category" value="">
            <label class="form-check-label">All</label>
          </div>

          <% categories.forEach(cat => { %>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="category" value="<%= cat %>">
            <label class="form-check-label"><%= cat %></label>
          </div>
          <% }) %>
        </div>

        <!-- SIZE -->
        <div class="mb-4">
          <p class="fw-semibold mb-2">Size</p>
          <hr>

          <div class="form-check">
            <input class="form-check-input" type="radio" name="size" value="">
            <label class="form-check-label">All</label>
          </div>

          <% sizes.forEach(size => { %>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="size" value="<%= size %>">
            <label class="form-check-label"><%= size %></label>
          </div>
          <% }) %>
        </div>

        <!-- COLOR -->
        <div class="mb-4">
          <p class="fw-semibold mb-2">Color</p>
          <hr>

          <div class="form-check">
            <input class="form-check-input" type="radio" name="color" value="">
            <label class="form-check-label">All</label>
          </div>

          <% colors.forEach(color => { %>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="color" value="<%= color %>">
            <label class="form-check-label"><%= color %></label>
          </div>
          <% }) %>
        </div>

        <button class="btn btn-success w-100 py-2">Apply Filters</button>

      </form>

    </div>

    <!-- 🟢 PRODUCTS -->
    <div class="col-lg-9">

      <div class="row">

        <% products.forEach(product => { %>

       <div class="col-xl-4 col-md-6 mb-4">

  <div class="product-card">

    <!-- IMAGE -->
    <div class="img-box">

      <img src="<%= product.image %>">

      <!-- ICONS -->
     <div class="action-icons">

  <a href="/edit/<%= product._id %>" class="icon edit">
    <i class="fa-solid fa-pen"></i>
  </a>

  <form action="/delete/<%= product._id %>" method="POST">
    <button class="icon delete">
      <i class="fa-solid fa-trash"></i>
    </button>
  </form>

</div>
    </div>

    <!-- CONTENT -->
    <div class="p-3 d-flex flex-column">

      <!-- TITLE -->
      <h6 class="fw-semibold mb-1"><%= product.name %></h6>

      <!-- DESCRIPTION -->
      <p class="text-muted small mb-2">
        <%= product.description.substring(0, 60) %>...
      </p>

      <!-- PRICE -->
      <p class="price mb-2">₹<%= product.price %></p>

      <!-- DETAILS -->
      <div class="small text-muted mb-3">

        <div><strong>Category:</strong> <%= product.category %></div>
        <div><strong>Size:</strong> <%= product.size %></div>
        <div><strong>Color:</strong> <%= product.color %></div>
        <div><strong>Stock:</strong> <%= product.stock %></div>

      </div>

    </div>

  </div>

</div>

        <% }) %>

      </div>

    </div>

  </div>

</div>

</body>
</html>