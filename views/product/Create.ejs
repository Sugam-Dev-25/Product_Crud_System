<!DOCTYPE html>
<html>
<head>

<title>Create Product</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<h3>Create Product</h3>

<form method="POST" action="/api/create">

<div class="row g-3">

<div class="col-md-6">
<input name="name" class="form-control" placeholder="Product Name">
</div>

<div class="col-md-6">
<input name="price" type="number" class="form-control" placeholder="Price">
</div>

<div class="col-md-12">
<textarea name="description" class="form-control" placeholder="Description"></textarea>
</div>

<div class="col-md-4">
<select name="category" class="form-select">
<% categories.forEach(cat => { %>
<option value="<%= cat %>"><%= cat %></option>
<% }) %>
</select>
</div>

<div class="col-md-4">
<select name="size" class="form-select">
<% sizes.forEach(size => { %>
<option value="<%= size %>"><%= size %></option>
<% }) %>
</select>
</div>

<div class="col-md-4">
<select name="color" class="form-select">
<% colors.forEach(color => { %>
<option value="<%= color %>"><%= color %></option>
<% }) %>
</select>
</div>

<div class="col-md-6">
<input name="stock" type="number" class="form-control" placeholder="Stock">
</div>

<div class="col-md-12">
<button class="btn btn-success">Create Product</button>
</div>

</div>

</form>

</div>

</body>
</html>