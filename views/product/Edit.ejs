<!DOCTYPE html>
<html>
<head>

<title>Edit Product</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<h3>Edit Product</h3>

<form method="POST" action="/update/<%= product._id %>">

<div class="row g-3">

<div class="col-md-6">
<input name="name" value="<%= product.name %>" class="form-control">
</div>

<div class="col-md-6">
<input name="price" value="<%= product.price %>" class="form-control">
</div>

<div class="col-md-12">
<textarea name="description" class="form-control"><%= product.description %></textarea>
</div>

<div class="col-md-4">
<select name="category" class="form-select">
<% categories.forEach(cat => { %>
<option value="<%= cat %>" <%= product.category===cat ? "selected":"" %>>
<%= cat %>
</option>
<% }) %>
</select>
</div>

<div class="col-md-4">
<select name="size" class="form-select">
<% sizes.forEach(size => { %>
<option value="<%= size %>" <%= product.size===size ? "selected":"" %>>
<%= size %>
</option>
<% }) %>
</select>
</div>

<div class="col-md-4">
<select name="color" class="form-select">
<% colors.forEach(color => { %>
<option value="<%= color %>" <%= product.color===color ? "selected":"" %>>
<%= color %>
</option>
<% }) %>
</select>
</div>

<div class="col-md-6">
<input name="stock" value="<%= product.stock %>" class="form-control">
</div>

<div class="col-md-12">
<button class="btn btn-primary">Update Product</button>
</div>

</div>

</form>

</div>

</body>
</html>